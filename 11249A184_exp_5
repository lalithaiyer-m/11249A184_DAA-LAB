#include <stdio.h>
#include <limits.h>

#define N 4

int graph[N][N] = {
    {0, 10, 15, 20},
    {10, 0, 35, 25},
    {15, 35, 0, 30},
    {20, 25, 30, 0}
};

int visited[N];
int tsp(int city, int count, int cost, int minCost) {
    if (count == N && graph[city][0]) {
        if (cost + graph[city][0] < minCost)
            minCost = cost + graph[city][0];
        return minCost;
    }

    for (int i = 0; i < N; i++) {
        if (!visited[i] && graph[city][i]) {
            visited[i] = 1;
            minCost = tsp(i, count + 1, cost + graph[city][i], minCost);
            visited[i] = 0;
        }
    }

    return minCost;
}

int main() {
    for (int i = 0; i < N; i++)
        visited[i] = 0;

    visited[0] = 1;

    int minCost = tsp(0, 1, 0, INT_MAX);

    printf("Minimum travelling cost = %d\n", minCost);

    return 0;
}
