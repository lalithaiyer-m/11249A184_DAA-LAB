#include <stdio.h>

#define V 4
#define E 5
struct Edge {
    int src, dest, weight;
};
int find(int parent[], int i) {
    if (parent[i] == i)
        return i;
    return find(parent, parent[i]);
}
void unionSet(int parent[], int x, int y) {
    parent[x] = y;
}
void sortEdges(struct Edge edges[]) {
    struct Edge temp;
    for (int i = 0; i < E - 1; i++) {
        for (int j = i + 1; j < E; j++) {
            if (edges[i].weight > edges[j].weight) {
                temp = edges[i];
                edges[i] = edges[j];
                edges[j] = temp;
            }
        }
    }
void kruskal(struct Edge edges[]) {
    struct Edge result[V];
    int parent[V];
    for (int i = 0; i < V; i++)
        parent[i] = i;

    sortEdges(edges);

    int e = 0; 
    int i = 0; 

    while (e < V - 1 && i < E) {
        struct Edge next = edges[i++];

        int x = find(parent, next.src);
        int y = find(parent, next.dest);
        if (x != y) {
            result[e++] = next;
            unionSet(parent, x, y);
        }
    }

    printf("Edge \tWeight\n");
    for (i = 0; i < e; i++) {
        printf("%d - %d \t%d\n",
               result[i].src,
               result[i].dest,
               result[i].weight);
    }
}

int main() {
    struct Edge edges[E] = {
        {0, 1, 10},
        {0, 2, 6},
        {0, 3, 5},
        {1, 3, 15},
        {2, 3, 4}
    };

    kruskal(edges);

    return 0;
}
