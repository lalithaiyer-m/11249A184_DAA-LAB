#include <stdio.h>

#define MAX 100

void firstFit(int weights[], int n, int capacity) {
    int bins[MAX];
    int binCount = 0;
    for (int i = 0; i < MAX; i++)
        bins[i] = 0;

    for (int i = 0; i < n; i++) {
        int placed = 0;
        for (int j = 0; j < binCount; j++) {
            if (bins[j] + weights[i] <= capacity) {
                bins[j] += weights[i];
                placed = 1;
                break;
            }
        }
        if (!placed) {
            bins[binCount] = weights[i];
            binCount++;
        }
    }

    printf("Minimum bins required (First Fit): %d\n", binCount);
}

int main() {
    int n, capacity;

    printf("Enter number of items: ");
    scanf("%d", &n);

    int weights[n];

    printf("Enter item weights:\n");
    for (int i = 0; i < n; i++)
        scanf("%d", &weights[i]);

    printf("Enter bin capacity: ");
    scanf("%d", &capacity);

    firstFit(weights, n, capacity);

    return 0;
}
